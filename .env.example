# KALAU SEBELUMNYA SUDAH DELEGATE, GAUSAH ISI PRIVATE_KEY ATAU OWNER_PRIVATE_KEY
# mint via MCP
MCP_URL=https://www.brainrot.dog/api/mcp
MINT_ADDRESS=0xyourdelegatedwalletaddress
# or set OWNER_PRIVATE_KEY / PRIVATE_KEY instead of MINT_ADDRESS
OWNER_PRIVATE_KEY=0xyourdelegatedwalletprivatekey
